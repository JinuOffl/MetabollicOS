# ══════════════════════════════════════════════════════════════════════════════
# GlucoNav — Root .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Secrets — NEVER commit these ──────────────────────────────────────────────
.env
backend/.env
**/.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Testing
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
cover/

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Cython
cython_debug/

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
conda/
.conda/

# ── GlucoNav — Database ─────────────────────────────────────────────────────
# The SQLite database is auto-created by `python run.py` + `seed_demo.py`
backend/gluconav.db
backend/*.db
backend/*.sqlite
backend/data/*.db
backend/data/*.sqlite

# ── GlucoNav — Trained ML model files ─────────────────────────────────────────
# Large binary files — regenerated by train_diet.py + train_exercise.py
backend/app/ml/models/*.pkl
backend/app/ml/models/*.npz

# ── GlucoNav — Generated data ─────────────────────────────────────────────────
# Regenerated by data_generator.py — do not commit
backend/data/interactions*.csv
backend/data/synthetic_users.csv

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
train_diet_out.txt
dart_files.txt

# ── Flutter / Dart ────────────────────────────────────────────────────────────
.dart_tool/
.packages
.pub-cache/
.pub/
frontend/OpenNutriTracker/build/
frontend/OpenNutriTracker/.dart_tool/
frontend/OpenNutriTracker/.flutter-plugins
frontend/OpenNutriTracker/.flutter-plugins-dependencies
frontend/OpenNutriTracker/.packages

# Hive local database (Flutter storage)
*.hive
*.lock.hive

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.ipr
*.iws
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Misc dev artifacts ────────────────────────────────────────────────────────
RecommendationEngine_implementation_plan
